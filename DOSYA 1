name: bordo_mavi_v61
description: Bordo Mavi V61 Projesi Mobil Uygulaması
version: 1.0.0+1

environment:
  sdk: ">=3.0.0 <4.0.0"

dependencies:
  flutter:
    sdk: flutter
  cupertino_icons: ^1.0.2
  # Buraya projenin özel fonksiyonları için ek paketler gelecek (örneğin: http, shared_preferences)

dev_dependencies:
  flutter_test:
    sdk: flutter
import 'package:flutter/material.dart';

void main() {
  runApp(BordoMaviV61App());
}

class BordoMaviV61App extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Bordo Mavi V61',
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        // Ana renk teması: Bordo (Maroon)
        primaryColor: Color(0xFF800000), 
        colorScheme: ColorScheme.fromSwatch().copyWith(
          secondary: Color(0xFF0000FF), // İkincil renk: Mavi
        ),
      ),
      home: AnaSayfa(),
    );
  }
}
import 'package:flutter/material.dart';

class AnaSayfa extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text("Bordo Mavi V61"),
        backgroundColor: Color(0xFF800000), // Bordo
      ),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(Icons.rocket_launch, size: 100, color: Color(0xFF0000FF)), // Mavi
            SizedBox(height: 20),
            Text(
              "V61 Projesi Aktif",
              style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold),
            ),
            Padding(
              padding: const EdgeInsets.all(20.0),
              child: Text(
                "Tüm sistemler stabil. APK üretimi için hazır.",
                textAlign: TextAlign.center,
              ),
            ),
            ElevatedButton(
              onPressed: () {
                print("V61 İşlem Tetiklendi");
              },
              style: ElevatedButton.styleFrom(backgroundColor: Color(0xFF800000)),
              child: Text("Sistemi Çalıştır", style: TextStyle(color: Colors.white)),
            )
          ],
        ),
      ),
    );
  }
}
